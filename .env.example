# Environment Variables Configuration
# Copy this file to .env to configure your local settings

# ==========================================
# DEVELOPMENT CONTROLS
# ==========================================

# Enable/disable dat.gui development controls
# Set to 'true' to show dat.gui interface for layout adjustment
# Only works in development mode - always disabled in production
VITE_ENABLE_DEV_CONTROLS=true

# Enable/disable the background video
# Set to 'false' to improve performance on slower devices
VITE_ENABLE_VIDEO=true

# ==========================================
# ADMIN DASHBOARD
# ==========================================

# Password for admin dashboard (default: byc123)
VITE_ADMIN_PASSWORD=byc123

# GitHub API token for remote content editing (deployed admin)
# Create at: https://github.com/settings/tokens (classic, repo scope)
# Leave empty for local-only mode (uses Express server)
VITE_GITHUB_TOKEN=

# GitHub repo settings (defaults shown, change if forked)
VITE_GITHUB_OWNER=ChenPaulYu
VITE_GITHUB_REPO=byc-web
VITE_GITHUB_BRANCH=main

# ==========================================
# HOW TO USE
# ==========================================

# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env with your preferred settings
#
# 3. Restart the development server:
#    npm run dev

# ==========================================
# NOTES
# ==========================================

# - .env is ignored by git (safe for local settings)
# - Production builds automatically disable dev controls
# - Changes require server restart to take effect
# - VITE_ prefixed vars are embedded at build time
