# Environment Variables Configuration
# Copy this file to .env to configure your local settings

# ==========================================
# DEVELOPMENT CONTROLS
# ==========================================

# Enable/disable dat.gui development controls
# Set to 'true' to show dat.gui interface for layout adjustment
# Set to 'false' to hide dat.gui
# Only works in development mode - always disabled in production
VITE_ENABLE_DEV_CONTROLS=true

# ==========================================
# HOW TO USE
# ==========================================

# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env with your preferred settings
#
# 3. Restart the development server:
#    npm run dev

# ==========================================
# NOTES
# ==========================================

# - .env is ignored by git (safe for local settings)
# - Production builds automatically disable dev controls
# - Changes require server restart to take effect